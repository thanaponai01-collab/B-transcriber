{
  "tokens": [
    {
      "text": "13 ปีที่เราคบกัน",
      "script": "thai",
      "start_ms": 0,
      "end_ms": 1240
    },
    {
      "text": "เราก็พอจะรู้",
      "script": "thai",
      "start_ms": 1240,
      "end_ms": 2040
    },
    {
      "text": "ว่าเขาเป็นคนเจ้าชู้",
      "script": "thai",
      "start_ms": 2040,
      "end_ms": 3500
    },
    {
      "text": "แต่เรามองว่าเขาเป็นคนดี",
      "script": "thai",
      "start_ms": 3500,
      "end_ms": 4820
    },
    {
      "text": "เขาดีทุกอย่าง",
      "script": "thai",
      "start_ms": 4820,
      "end_ms": 5780
    },
    {
      "text": "คือเขาขอตั้งแต่วันแรก",
      "script": "thai",
      "start_ms": 5780,
      "end_ms": 6880
    },
    {
      "text": "ที่รู้เลยว่า",
      "script": "thai",
      "start_ms": 6880,
      "end_ms": 7480
    },
    {
      "text": "ขออยู่แบบ 3 คน แบบนี้ได้ไหม",
      "script": "thai",
      "start_ms": 7480,
      "end_ms": 9260
    },
    {
      "text": "เรารู้สึกว่า เราแบบ",
      "script": "thai",
      "start_ms": 9260,
      "end_ms": 10000
    },
    {
      "text": "ไม่ได้ยังไงก็ไม่ได้",
      "script": "thai",
      "start_ms": 10000,
      "end_ms": 11040
    },
    {
      "text": "เพราะว่า  มันเป็นความสัมพันธ์",
      "script": "thai",
      "start_ms": 11040,
      "end_ms": 12100
    },
    {
      "text": "ที่มันไม่ถูกต้อง",
      "script": "thai",
      "start_ms": 12100,
      "end_ms": 13480
    },
    {
      "text": "เขาให้เหตุผลว่าใครๆ  ก็ทำแบบนี้กันทั้งนั้น",
      "script": "thai",
      "start_ms": 13480,
      "end_ms": 15900
    },
    {
      "text": "<font color=#59E2FEFF>นี่ไง</font>",
      "script": "mixed",
      "start_ms": 15900,
      "end_ms": 16260
    },
    {
      "text": "อย่าให้เขารู้สึก",
      "script": "thai",
      "start_ms": 16260,
      "end_ms": 17000
    },
    {
      "text": "ตัวเองเลอค่าเกินไปนัก คุณ",
      "script": "thai",
      "start_ms": 17000,
      "end_ms": 18920
    },
    {
      "text": "เขาก็แค่สามีเจ้าชู้ที่นอกใจ",
      "script": "thai",
      "start_ms": 18920,
      "end_ms": 21240
    },
    {
      "text": "และทำร้ายลูก ทำร้ายครอบครัว",
      "script": "thai",
      "start_ms": 21240,
      "end_ms": 22960
    },
    {
      "text": "เราอย่าไปให้ค่าเขาเกินจริง",
      "script": "thai",
      "start_ms": 22960,
      "end_ms": 24740
    },
    {
      "text": "พี่ถึงเข้าใจเสมอว่า",
      "script": "thai",
      "start_ms": 24740,
      "end_ms": 26040
    },
    {
      "text": "การที่เราจะต้องออก ไปจากชีวิตของคนที่เรารักอ่ะ",
      "script": "thai",
      "start_ms": 26040,
      "end_ms": 27980
    },
    {
      "text": "มันยากอยู่แล้ว",
      "script": "thai",
      "start_ms": 27980,
      "end_ms": 29380
    },
    {
      "text": "เพียงแต่แค่บังเอิญ เขาไม่น่ารักมากพอ",
      "script": "thai",
      "start_ms": 29380,
      "end_ms": 31220
    },
    {
      "text": "ให้หนูเดินต่อค่ะ",
      "script": "thai",
      "start_ms": 31220,
      "end_ms": 32400
    }
  ]
}